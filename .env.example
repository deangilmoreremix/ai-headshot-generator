# Environment Configuration for AI Headshot Generator

# Supabase (Required)
NEXT_PUBLIC_SUPABASE_URL="your_supabase_url"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"

# AI Headshot API
HEADSHOT_API_KEY="your_muapi_ai_key"
WEBHOOK_URL="your_webhook_url"  # Used for muapi.ai webhook callbacks

# Stripe (Optional - for payments)
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# App URL (for redirects)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# NextAuth (Legacy - no longer required)
# NEXTAUTH_URL="http://localhost:3000"
# NEXTAUTH_SECRET="your_nextauth_secret_here"

# Google Auth (Legacy - no longer required)
# GOOGLE_CLIENT_ID="your_google_id_here"
# GOOGLE_CLIENT_SECRET="your_google_secret_here"

# Dynamic UI Theme Configuration
# Choose between: indigo, emerald, rose, amber, violet
NEXT_PUBLIC_THEME=dark